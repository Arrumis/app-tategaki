# tategaki の基本設定です。
# 縦書きリーダー本体の公開ポート、保存先、巡回間隔をここで決めます。

# Web アプリをホストで公開するポートです。
# ブラウザでは http://localhost:APP_PORT で開きます。
# reverse proxy 配下で使う場合も、まずはこのローカルポートへ流します。
APP_PORT=3000

# ホスト側の永続化データ保存先です。
# お気に入り、小説本文、ログ、ユーザー情報などはここへ保存されます。
# PC を移すときに持ち運びたい実データは、このディレクトリ配下にあります。
HOST_DATA_DIR=./data

# コンテナから見たデータ保存先です。
# ふつうは HOST_DATA_DIR と同じ意味で使うので、そのままで構いません。
# 特別な理由がなければ HOST_DATA_DIR だけ見れば十分です。
TATEGAKI_DATA_DIR=./data

# コンテナ内タイムゾーンです。
# ログ時刻や定期ジョブの基準に使います。
TZ=Asia/Tokyo

# 定期巡回の間隔です。単位はミリ秒です。
# 10800000 = 3時間ごとです。
# 小さくしすぎると外部サイトへの巡回が増えるので、通常は既定値のままで十分です。
CRAWL_INTERVAL_MS=10800000

# 1リクエストごとの待ち時間です。単位はミリ秒です。
# 外部サイトへ連続アクセスしすぎないための delay です。
# 3000 = 3秒待ちです。通常は既定値のままで構いません。
REQUEST_DELAY_MS=3000
